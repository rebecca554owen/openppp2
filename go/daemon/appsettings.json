{
  "listen": ":18080",
  "managedApi": {
    "baseUrl": "http://127.0.0.1:10000",
    "prefix": "/api/managed/"
  },
  "instance": {
    "name": "ppp",
    "binary": "./openppp2",
    "workDir": "../..",
    "configPath": "./appsettings.json",
    "args": [
      "--mode=client",
      "--configuration=./appsettings.json"
    ],
    "env": {},
    "stopSignal": "interrupt",
    "stopWaitMs": 5000,
    "logLines": 400
  },
  "ui": {
    "title": "OpenPPP2 Daemon"
  }
}
